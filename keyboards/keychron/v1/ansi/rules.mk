# Enable VIA support
VIA_ENABLE = yes

# Enable Leader Key functionality
LEADER_ENABLE = yes
LEADER_TIMEOUT = 300
LEADER_PER_KEY_TIMING = yes

# Optional but useful features you may want
TAP_DANCE_ENABLE = yes        # Enables multi-tap actions per key (e.g., tap once = Esc, tap twice = Caps Lock)
COMBO_ENABLE = yes            # Enables pressing multiple keys together to trigger another key
UNICODE_ENABLE = yes          # Allows Unicode character input

# Debugging / Development tools (optional)
CONSOLE_ENABLE = yes          # Enable debug printing with `uprintf`
COMMAND_ENABLE = no           # Disables rarely used built-in command mode
